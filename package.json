{
  "name": "lume",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron -r ts-node/register src/main/main.ts\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.json && node ./scripts/copy-preload.js",
    "build": "npm run build:renderer && npm run build:main && electron-builder --win --x64",
    "start": "electron .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "axios": "^1.18.1",
    "firebase": "^12.15.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "systeminformation": "^5.31.14"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.6.1",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.8",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.lume.app",
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "portable"
    }
  }
}
